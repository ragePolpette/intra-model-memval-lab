# Input source
SOURCE_MEMORY_DB=../llm-memory/data/memory.db

# Output
OUTPUT_DIR=./data
OUTPUT_JSONL=./data/memval_dataset.jsonl
OUTPUT_NUMERIC_JSONL=./data/memval_numeric.jsonl
OUTPUT_TEXT_JSONL=./data/memval_text_shadow.jsonl

# Modality
MODALITY_PRIMARY=numeric
REQUIRE_NUMERIC=true
ALLOW_TEXT_SHADOW=true

# Selection policy
NOVELTY_MIN=0.2
TOP_RATIO=0.60
MID_RATIO=0.25
LOW_RATIO=0.15
EXTERNAL_MIN_RATIO=0.25
SAMPLE_SIZE=
RANDOM_SEED=42

# Hardening policy
ENFORCE_PROVENANCE=true
ENFORCE_EXTERNAL_EVIDENCE=true
SELF_EVAL_ENFORCED=false
MAX_PER_WRITER=0.20
MAX_PER_CONVERSATION=0.05
